# ============================================
# Whisper Blog API — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL via Docker) ─────────
DATABASE_URL=postgresql://whisper:whisper_secret@localhost:5432/whisper_blog_dev?schema=public
DATABASE_USERNAME=whisper
DATABASE_PASSWORD=whisper_secret
DATABASE_NAME=whisper_blog_dev

# ── JWT ──────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-me-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Redis (via Docker) ──────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MinIO / S3 (via Docker) ─────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=whisper-uploads
MINIO_USE_SSL=false

# ── Rate Limiting ────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10
